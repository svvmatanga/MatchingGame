<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg11"
    tools:context=".MainActivity">

    <Button
        android:id="@+id/options"
        android:layout_width="306dp"
        android:layout_height="68dp"
        android:layout_marginTop="450dp"
        android:fontFamily="@font/lilita_one"
        android:backgroundTint="#FEBA17"
        android:textColor="#614e25"
        android:textSize="24sp"
        android:text="OPTIONS"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.497"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>

    <Button
        android:id="@+id/crdcata"
        android:layout_width="306dp"
        android:layout_height="68dp"
        android:layout_marginTop="28dp"
        android:fontFamily="@font/lilita_one"
        android:backgroundTint="#FEBA17"
        android:textColor="#614e25"
        android:textSize="24sp"
        android:text="CARD CATALOGUE"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.497"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/options" />

    <Button
        android:id="@+id/scrbrd"
        android:layout_width="306dp"
        android:layout_height="68dp"
        android:layout_marginTop="28dp"
        android:fontFamily="@font/lilita_one"
        android:backgroundTint="#FEBA17"
        android:textColor="#614e25"
        android:textSize="24sp"
        android:text="SCOREBOARD"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.497"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/crdcata" />

    <Button
        android:id="@+id/exit"
        android:layout_width="306dp"
        android:layout_height="68dp"
        android:layout_marginTop="28dp"
        android:fontFamily="@font/lilita_one"
        android:backgroundTint="#FEBA17"
        android:textColor="#614e25"
        android:textSize="24sp"
        android:text="EXIT"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.497"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/scrbrd" />
</androidx.constraintlayout.widget.ConstraintLayout>
