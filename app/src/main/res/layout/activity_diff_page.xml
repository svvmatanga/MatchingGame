<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:background="@drawable/bg8"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".DiffPage">

    <!-- Difficulty Selection Buttons -->
    <!-- Set this to the top of the parent -->

    <!-- This refers to buttonEasy -->

    <Button
        android:id="@+id/buttonEasy"
        android:layout_width="220dp"
        android:layout_height="68dp"
        android:layout_marginTop="530dp"
        android:backgroundTint="#E91E63"
        android:textSize="24sp"
        android:text="EASY"
        android:fontFamily="@font/lilita_one"
        android:textColorLink="#E91E63"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.497"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <Button
        android:id="@+id/buttonMedium"
        android:layout_width="220dp"
        android:layout_height="68dp"
        android:layout_marginTop="28dp"
        android:backgroundTint="#E91E63"
        android:fontFamily="@font/lilita_one"
        android:textSize="24sp"
        android:text="MEDIUM"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.497"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/buttonEasy" />

    <Button
        android:id="@+id/buttonHard"
        android:layout_width="220dp"
        android:layout_height="68dp"
        android:layout_marginTop="28dp"
        android:backgroundTint="#E91E63"
        android:textSize="24sp"
        android:fontFamily="@font/lilita_one"
        android:text="HARD"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.497"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/buttonMedium" />

    <Button
        android:id="@+id/backbtn"
        android:layout_width="91dp"
        android:layout_height="48dp"
        android:layout_marginTop="40dp"
        android:backgroundTint="#E91E63"
        android:text="Back"
        android:textColor="#FFFFFF"
        android:fontFamily="@font/lilita_one"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.046"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" /> <!-- This refers to buttonMedium -->

</androidx.constraintlayout.widget.ConstraintLayout>
